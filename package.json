{
  "name": "magnit-management",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tauri": "tauri",
    "check:unused": "ts-prune",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:8000 && NODE_ENV=development electron .\"",
    "electron:build": "ELECTRON=true vite build && electron-builder",
    "electron:build:win": "ELECTRON=true vite build && electron-builder --win",
    "electron:build:mac": "ELECTRON=true vite build && electron-builder --mac",
    "electron:build:linux": "ELECTRON=true vite build && electron-builder --linux"
  },
  "build": {
    "appId": "uz.magnit.pos",
    "productName": "Magnit POS",
    "copyright": "Copyright © 2024 Magnit",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public/icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon-512.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon-512.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fortawesome/fontawesome-svg-core": "^6.4.0",
    "@fortawesome/free-solid-svg-icons": "^6.4.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@mui/icons-material": "^6.1.9",
    "@mui/lab": "^5.0.0-alpha.142",
    "@mui/material": "^5.14.0",
    "@mui/styles": "^5.14.0",
    "@mui/system": "^6.1.10",
    "@mui/x-tree-view": "^7.23.2",
    "@reduxjs/toolkit": "^1.9.5",
    "ag-grid-community": "^30.0.5",
    "ag-grid-react": "^30.0.5",
    "axios": "^1.4.0",
    "dayjs": "^1.11.7",
    "file-saver": "^2.0.5",
    "history": "^5.3.0",
    "i18next": "^24.0.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.553.0",
    "mixpanel-browser": "^2.56.0",
    "qrcode.react": "^4.2.0",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-barcode": "^1.5.3",
    "react-circular-progressbar": "^2.1.0",
    "react-datepicker": "^4.16.0",
    "react-day-picker": "^7.4.10",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-highlight-words": "^0.20.0",
    "react-hook-form": "^7.45.2",
    "react-hotkeys-hook": "^4.6.1",
    "react-i18next": "^15.1.1",
    "react-imask": "^7.1.3",
    "react-input-mask": "^2.0.4",
    "react-intersection-observer": "^9.16.0",
    "react-number-format": "^5.4.2",
    "react-outside-click-handler": "^1.3.0",
    "react-query": "^3.39.3",
    "react-redux": "^8.1.1",
    "react-router-dom": "^6.14.2",
    "react-select": "^5.7.4",
    "react-sortable-hoc": "^2.0.0",
    "react-table": "^7.8.0",
    "react-to-print": "^2.12.4",
    "react-toastify": "^9.1.3",
    "react-use": "^17.5.1",
    "react-yandex-maps": "^4.6.0",
    "recharts": "^2.8.0",
    "redux-persist": "^6.0.0",
    "svelte-sonner": "^1.0.1",
    "use-debounce": "^9.0.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.50",
    "@types/react-dom": "^18.2.6",
    "@vitejs/plugin-react": "^4.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.44.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "ts-prune": "^0.10.3",
    "unimported": "^1.31.1",
    "vite": "^4.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  }
}
