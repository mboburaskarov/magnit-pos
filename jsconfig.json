{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["components/*"],
      "@utils/*": ["utils/*"],
      "@constants/*": ["constants/*"],
      "@icons/*": ["src/assets/icons/*"],
      "@hooks/*": ["src/hooks/*"]
    },
    // "checkJs": true,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
